{
  "name": "eventlens-server",
  "version": "1.0.0",
  "description": "backend for eventlens project",
  "author": "Ankit Ydv",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "rimraf dist",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "express": "^5.2.1",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.3",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
